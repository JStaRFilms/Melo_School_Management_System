# Convex Configuration
# Get your Convex URL by running: npx convex dev
# This will create a new Convex project and provide you with the URL
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-project.convex.site

# Better Auth Configuration
BETTER_AUTH_SECRET=your-secret-key-here
SITE_URL=http://localhost:3001

# Trusted Origins (comma-separated)
TRUSTED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004

# OpenRouter AI Configuration (server-only)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_HTTP_REFERER=http://localhost:3001
OPENROUTER_APP_TITLE=School Management System Teacher

# Optional: Per-output model overrides
# SCHOOL_AI_LESSON_PLAN_MODEL=your-openrouter-model-id
# SCHOOL_AI_STUDENT_NOTE_MODEL=your-openrouter-model-id
# SCHOOL_AI_ASSIGNMENT_MODEL=your-openrouter-model-id
# SCHOOL_AI_QUESTION_BANK_MODEL=your-openrouter-model-id
# SCHOOL_AI_CBT_MODEL=your-openrouter-model-id

# Optional: For production
# NODE_ENV=production
