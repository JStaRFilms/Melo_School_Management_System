{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "ignorePatterns": [
    "node_modules/",
    ".next/",
    ".turbo/",
    "dist/",
    "coverage/",
    "*.tsbuildinfo",
    "packages/convex/_generated/",
    "apps/admin/convex/",
    "apps/teacher/convex/"
  ]
}
